      "displayName": "Formula One Driver Rankings Since 2014 Comparison",
      "queryLines": [
        "USE CATALOG `formula1`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "select * \n",
        "from vw_driver_standings\n",
        "where driver_name in ('Max Verstappen', 'Lewis Hamilton')\n",
        "AND season >= 2014\n",
        "order by season"
