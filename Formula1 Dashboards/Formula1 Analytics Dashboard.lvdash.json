    {
      "name": "6f984df9",
      "displayName": "dominant_drivers",
      "queryLines": [
        "WITH driver_metrics AS\r\n",
        "(\r\n",
        "    SELECT driver_name,\r\n",
        "        SUM(race_starts) AS race_starts,\r\n",
        "        SUM(wins) AS total_wins,\r\n",
        "        SUM(podiums) AS total_podiums,\r\n",
        "        SUM(CASE WHEN standings = 1 THEN 1 ELSE 0 END) AS total_championship\r\n",
        "    FROM vw_driver_standings\r\n",
        "    GROUP BY driver_name\r\n",
        "    HAVING total_championship >= 1\r\n",
        ")\r\n",
        "SELECT driver_name,\r\n",
        "    race_starts,\r\n",
        "    total_wins,\r\n",
        "    total_podiums,\r\n",
        "    total_championship,\r\n",
        "    (total_championship * 100) + (total_wins * 10) + (total_podiums * 3) AS greatness_score\r\n",
        "FROM driver_metrics\r\n",
        "ORDER BY greatness_score DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "formula1",
      "schema": "gold"
    },
    {
      "name": "9660099e",
      "displayName": "dominant_teams",
      "queryLines": [
        "WITH constructor_metrics AS\r\n",
        "(\r\n",
        "    SELECT constructor_name,\r\n",
        "        SUM(race_starts) AS race_starts,\r\n",
        "        SUM(wins) AS total_wins,\r\n",
        "        SUM(podiums) AS total_podiums,\r\n",
        "        SUM(CASE WHEN standings = 1 THEN 1 ELSE 0 END) AS total_championship\r\n",
        "    FROM vw_constructor_standings\r\n",
        "    GROUP BY constructor_name\r\n",
        "    HAVING total_championship >= 1\r\n",
        ")\r\n",
        "SELECT constructor_name,\r\n",
        "    race_starts,\r\n",
        "    total_wins,\r\n",
        "    total_podiums,\r\n",
        "    total_championship,\r\n",
        "    (total_championship * 100) + (total_wins * 10) + (total_podiums * 3) AS greatness_score\r\n",
        "FROM constructor_metrics\r\n",
        "ORDER BY greatness_score DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "formula1",
      "schema": "gold"
    }
  ],
